# Quarto build artifacts
/.quarto/
**/.quarto/
_site/
_book/
_freeze/
*.html
*.pdf

# Theme assets shipped with the extension. Negated explicitly because
# the broad `*.html` glob above otherwise swallows them. Discovered the
# hard way: v1.2.0 went out missing fmup-fonts.html because of this.
!_extensions/fmup/fmup-fonts.html

# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

/.luarc.json

# Visual-regression scaffold
tests/visual/node_modules/
tests/visual/test-results/
tests/visual/playwright-report/

# Quarto compile diagnostics (regenerated on each render)
_quarto_internal_scss_error.scss
